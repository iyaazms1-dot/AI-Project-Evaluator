{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A student's project submission.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "githubLink": { "type": "string" },
        "content": { "type": "string" },
        "contentType": { "type": "string", "enum": ["text", "pdf", "ppt"] },
        "status": { "type": "string", "enum": ["pending", "evaluated"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "title", "status"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "AI or admin generated evaluation for a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "studentId": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "innovation": { "type": "number" },
            "technicalDepth": { "type": "number" },
            "clarity": { "type": "number" },
            "impact": { "type": "number" },
            "overall": { "type": "number" }
          }
        },
        "feedback": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "evaluatedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "projectId", "scores", "feedback"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project submission documents."
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Evaluation result documents."
    }
  }
}
