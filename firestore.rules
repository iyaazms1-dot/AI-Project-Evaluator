rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "iyaazms1@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'admin'];
    }

    function isValidProject(data) {
      return data.keys().hasAll(['studentId', 'title', 'status', 'createdAt']) &&
             data.studentId is string &&
             data.title is string &&
             data.status in ['pending', 'evaluated'];
    }

    function isValidEvaluation(data) {
      return data.keys().hasAll(['projectId', 'scores', 'feedback', 'createdAt']) &&
             data.projectId is string &&
             data.scores is map &&
             data.feedback is string;
    }

    // User Profile Rules
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
    }

    // Project Rules
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId) && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin()) && isValidProject(request.resource.data);
      allow delete: if isAdmin();
    }

    // Evaluation Rules
    match /evaluations/{evaluationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin());
      allow create: if isAuthenticated(); // AI service or Admin
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
